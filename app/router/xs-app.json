{
  "welcomeFile": "/project1/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/odata/v4/logi-chain/(.*)$",
      "target": "/odata/v4/logi-chain/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/project1/(.*)$",
      "target": "/project1/$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    }
  ]
}