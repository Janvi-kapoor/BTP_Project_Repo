<mvc:View controllerName="project1.controller.DriverDashboard" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:tnt="sap.tnt" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" displayBlock="true">
    <tnt:ToolPage id="toolPage">
        <tnt:header>
            <tnt:ToolHeader id="mainHeader" class="nexusHeader">
                <Button id="sideNavBtn" icon="sap-icon://menu2" type="Transparent" press="onSideNavButtonPress" class="headerMenuBtn">
                    <layoutData>
                        <OverflowToolbarLayoutData id="sideNavBtnLayoutData" priority="NeverOverflow"/>
                    </layoutData>
                </Button>
                <HBox id="logoBox" alignItems="Center" class="logoContainer">
                    <core:Icon id="_IDGenIcon8" src="sap-icon://connected" class="logoIcon"/>
                    <Title id="_IhDGenTitle5" text="CargoConnect" class="companyLogoText"/>
                </HBox>
                <ToolbarSpacer id="_IDGefnToolbarSpacer5"/>
                <HBox id="rightSection" alignItems="Center">
                    <HBox id="profileBox" alignItems="Center" class="profileSection">
                        <Avatar id="_IDGenfAvatar" src="sap-icon://person-placeholder" displaySize="XS" class="profileAvatar"/>
                        <VBox id="_IDGenfVBox11" alignItems="Start" justifyContent="Center" class="profileInfoBox sapUiTinyMarginBegin sapUiHideOnPhone">
                            <Text id="_IDGfenText18" text="{driverData>/driverName}" class="profileName"/>
                            <Text id="_IDGenfText19" text="Driver" class="profileRole"/>
                        </VBox>
                        <Button id="logoutBtn" icon="sap-icon://log" type="Transparent" class="headerIconBtn sapUiTinyMarginBegin" tooltip="Logout" press="onLogout"/>
                    </HBox>
                </HBox>
            </tnt:ToolHeader>
        </tnt:header>
        <tnt:sideContent>
            <tnt:SideNavigation id="sideNavigation" itemSelect="onItemSelect" class="nexusSidebar">
                <tnt:item>
                    <tnt:NavigationList id="navList">
                        <tnt:NavigationListItem id="_IDGenNavigationListItem" text="Active Mission" icon="sap-icon://locate-me" key="mission"/>
                        <tnt:NavigationListItem id="_IDGenNavigationListItem4" text="Live Navigation" icon="sap-icon://map-2" key="navigation"/>
                        <tnt:NavigationListItem id="_IDGenNavigationListItem6" text="Secure Delivery" icon="sap-icon://shield" key="secure"/>
                        <tnt:NavigationListItem id="_IDGenNavigationListItem7" text="My Performance" icon="sap-icon://performance" key="performance"/>
                    </tnt:NavigationList>
                </tnt:item>
            </tnt:SideNavigation>
        </tnt:sideContent>
        <tnt:mainContents>
            <NavContainer id="driverNavContainer">
                <Page id="missionPage" showHeader="false">
                    <VBox id="activeMissionContainer" class="contentPadding performancePageContainer">
                        <HBox id="activeMissionHeader" alignItems="Center" class="performanceHeaderBox">
                            <core:Icon id="missionIcon" src="sap-icon://marketing-campaign" class="performanceHeaderIcon"/>
                            <Title id="missionTitle" text="Active Mission" class="mainTitleText"/>
                        </HBox>
                       <HBox id="driverInfoBox" wrap="Wrap" class="sapUiMediumMarginBottom sapUiMediumMarginBegin mar driverInfoContainer">
    
    <HBox id="driverPill" alignItems="Center" class="drActive-infoPill sapUiMediumMarginEnd">
        <VBox class="drActive-pillIcon drActive-driverIcon">
            <core:Icon src="sap-icon://employee"/>
        </VBox>
        <VBox class="drActive-pillContent">
            <Text id="driverLabel" text="Driver" class="drActive-tinyLabel"/>
            <Text id="driverName" text="{driverData>/driverName}" class="drActive-pillMainText"/>
        </VBox>
    </HBox>

    <HBox id="truckPill" alignItems="Center" class="drActive-infoPill">
        <VBox class="drActive-pillIcon drActive-truckIcon">
            <core:Icon src="sap-icon://vehicle-repair"/>
        </VBox>
        <VBox class="drActive-pillContent">
            <Text id="truckLabel" text="Truck" class="drActive-tinyLabel"/>
            <Text id="truckNumber" text="{driverData>/truckNo}" class="drActive-pillMainText"/>
        </VBox>
    </HBox>

</HBox>
                        <!-- Clean Mission Layout -->
                        <VBox class="drActive-cleanLayout" id="missionContainer">
                            <!-- Shipment Header -->
                            <HBox id="missionHeaderBox" justifyContent="SpaceBetween" alignItems="Center" class="drActive-shipmentHeader">
                                <VBox id="shipmentInfoVBox">
                                    <Text id="shipmentLabel" text="ACTIVE SHIPMENT" class="drActive-tinyLabel"/>
                                    <Title id="shipmentID" text="{driverData>/ID}" titleStyle="H1" class="drActive-mainShipmentID"/>
                                </VBox>
                                <ObjectStatus id="missionStatus" text="{driverData>/status}" state="{= ${driverData>/status} === 'In-Transit' ? 'Success' : 'Warning' }" inverted="false"/>
                            </HBox>
                            <!-- Route & Details Cards -->
                            <HBox class="drActive-cardsContainer">
                                <!-- Route Card -->
                                <VBox class="drActive-routeCard">
                                    <Text text="ROUTE" class="drActive-cardTitle"/>
                                    <VBox class="drActive-routeContent">
                                        <HBox alignItems="Center" class="drActive-routeItem">
                                            <VBox class="drActive-routeIcon">
                                                <core:Icon src="sap-icon://map-2" class="sapUiIcon"/>
                                            </VBox>
                                            <VBox class="drActive-routeInfo">
                                                <Text text="FROM" class="drActive-routeLabel"/>
                                                <Text id="originLocation" text="{driverData>/pickupLocation}" class="drActive-routeValue"/>
                                            </VBox>
                                        </HBox>
                                        <VBox class="drActive-routeLine">
                                            <VBox class="drActive-routeDots">
                                                <VBox class="drActive-dot"/>
                                                <VBox class="drActive-dot"/>
                                                <VBox class="drActive-dot"/>
                                            </VBox>
                                            <VBox class="drActive-truckInRoute">
                                                <core:Icon src="sap-icon://vehicle-repair" class="sapUiIcon"/>
                                            </VBox>
                                        </VBox>
                                        <HBox alignItems="Center" class="drActive-routeItem">
                                            <VBox class="drActive-routeIcon">
                                                <core:Icon src="sap-icon://flag-2" class="sapUiIcon"/>
                                            </VBox>
                                            <VBox class="drActive-routeInfo">
                                                <Text text="TO" class="drActive-routeLabel"/>
                                                <Text id="destinationLocation" text="{driverData>/dropLocation}" class="drActive-routeValue"/>
                                            </VBox>
                                        </HBox>
                                    </VBox>
                                </VBox>
                                <!-- Details Card -->
                                <VBox class="drActive-detailsCard">
                                    <Text text="SHIPMENT DETAILS" class="drActive-cardTitle"/>
                                    <VBox class="drActive-detailsContent">
                                        <HBox alignItems="Center" class="drActive-detailRow">
                                            <core:Icon id="weightIcon" src="sap-icon://measuring-point" class="drActive-detailIcon"/>
                                            <VBox class="drActive-detailInfo">
                                                <Text text="LOAD WEIGHT" class="drActive-detailLabel"/>
                                                <Text id="weightValue" text="{driverData>/loadWeightTons} Tons" class="drActive-detailValue"/>
                                            </VBox>
                                        </HBox>
                                        <HBox alignItems="Center" class="drActive-detailRow">
                                            <core:Icon id="cargoIcon" src="sap-icon://cargo-train" class="drActive-detailIcon"/>
                                            <VBox class="drActive-detailInfo">
                                                <Text text="CARGO TYPE" class="drActive-detailLabel"/>
                                                <Text id="cargoValue" text="{driverData>/materialCategory}" class="drActive-detailValue"/>
                                            </VBox>
                                        </HBox>
                                        <HBox alignItems="Center" class="drActive-detailRow">
                                            <core:Icon id="durationIcon" src="sap-icon://time-entry-request" class="drActive-detailIcon"/>
                                            <VBox class="drActive-detailInfo">
                                                <Text text="EST. DURATION" class="drActive-detailLabel"/>
                                                <Text id="durationValue" text="{driverData>/eta}" class="drActive-detailValue"/>
                                            </VBox>
                                        </HBox>
                                    </VBox>
                                </VBox>
                            </HBox>
                            <!-- Action Button -->
                            <VBox class="drActive-actionContainer">
                                <Button id="startMissionBtn" text="START MISSION" type="Emphasized" press="onStartTrip" class="drActive-startBtn" icon="sap-icon://play" iconFirst="false" visible="{= ${driverData>/status} === 'Assigned' }"/>
                                <VBox id="tripStartedMessage" visible="{= ${driverData>/status} === 'In-Transit' || ${driverData>/status} === 'ConfirmPickup' }" alignItems="Center" class="drActive-successMessage">
                                    <core:Icon id="_IDGenIcon17" src="sap-icon://accept" class="drActive-successIcon"/>
                                    <Text id="_IDGenText45" text="{= ${driverData>/status} === 'In-Transit' ? 'The trip has started' : 'Pickup confirmed - Ready for delivery' }" class="drActive-successText"/>
                                </VBox>
                            </VBox>
                        </VBox>
                        <l:Grid id="kpiGrid" defaultSpan="L4 M6 S12" class="sapUiMediumMarginTop sapUiMediumMarginBeginEnd drActive-kpiContainer">
                            <VBox id="distanceKpiCard" class="drActive-kpiCard">
                                <Text id="_IDGenText46" text="Total Distance" class="drActive-tinyLabel"/>
                                <Title id="_IDGenTitle18" text="{driverData>/totalDistance} KM" titleStyle="H2"/>
                            </VBox>
                            <VBox id="rateKpiCard" class="drActive-kpiCard">
                                <Text id="_IDGenText47" text="Assigned Truck Type" class="drActive-tinyLabel"/>
                                <Title id="_IDGenTitle19" text="{driverData>/truckType}" titleStyle="H2" class="sapUiPositiveText"/>
                            </VBox>
                            <VBox id="fareKpiCard" class="drActive-kpiCard">
                                <Text id="_IDGenText49" text="Trip Fare" class="drActive-tinyLabel"/>
                                <Title id="_IDGenTitle17" text="{
           parts: [
               {path: 'driverData>/totalFare'},
               {value: 'INR'}
           ],
           type: 'sap.ui.model.type.Currency',
           formatOptions: {
               showMeasure: true,
               currencyCode: false
           }
       }" titleStyle="H2" class="fareTitle"/>
                            </VBox>
                        </l:Grid>
                    </VBox>
                    <VBox id="noTaskContainer" visible="false" alignItems="Center" class="sapUiLargeMarginTop">
                        <core:Icon id="_IDGenIcon16" src="sap-icon://message-success" size="4rem" color="#ccc"/>
                        <Title id="_IDGenTitle16" text="No tasks currently assigned to you." class="sapUiSmallMarginTop"/>
                        <Text id="_IDGenText44" text="Please wait for the administrator to assign a new shipment."/>
                    </VBox>
                </Page>
            </NavContainer>
        </tnt:mainContents>
    </tnt:ToolPage>
</mvc:View>