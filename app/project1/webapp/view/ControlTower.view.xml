<mvc:View controllerName="project1.controller.ControlTower" 
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns="sap.m"
    xmlns:tnt="sap.tnt" 
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    >

    <VBox id="_IDGenVBox11" class="mainDashboardContent">
        
        <VBox id="_IDGenTitleeBox" class="pageHeaderSection">
             <Title id="_IDGenTitle6" text="Control Tower" class="premiumTitle" />
             <Text id="_IDGenText17" text="Real-time fleet monitoring and insights" class="premiumSubtitle" />
        </VBox>

        <HBox id="_IDGenHBox5" justifyContent="Start" wrap="Wrap" class="kpiContainer">
            <GenericTile id="_IDGenGenericTile" header="Total Revenue" class="customTile alertTile">
                <TileContent id="_IDGenTileContent" >
                    <NumericContent 
                        id="_IDGenNumericContent" 
                        value="{dashboard>/stats/revenue}" 
                        valueColor="Neutral"
                        icon="sap-icon://money-bills"
                        withMargin="false" 
                        truncateValueTo="10"/>
                </TileContent>
            </GenericTile>

            <GenericTile id="_IDGenGenericTile1" header="Total Commission" class="customTile">
                <TileContent id="_IDGenTileContent1">
                    <NumericContent 
                        id="_IDGenNumericContent1" 
                        value="{dashboard>/stats/commission}" 
                        valueColor="Good" 
                        icon="sap-icon://currency"
                        withMargin="false"
                        truncateValueTo="10" />
                </TileContent>
            </GenericTile>

            <GenericTile id="_IDGenGenericTile2" header="Active Drivers" class="customTile">
                <TileContent id="_IDGenTileContent2">
                    <NumericContent 
                        id="_IDGenNumericContent2" 
                        value="{dashboard>/stats/activeDrivers}" 
                        valueColor="Good" 
                        icon="sap-icon://shipping-status"
                        withMargin="false" />
                </TileContent>
            </GenericTile>
        </HBox>

        <layout:Grid id="_IDGenGrid1" defaultSpan="L8 M12 S12" vSpacing="1" hSpacing="0.5">
            <VBox id="_IDGenVBox12" height="450px" class="dashboardMapStyle">
            
                <layoutData><layout:GridData id="_IDGenGridData" span="L8 M12 S12" /></layoutData>
                <Title id="_IDGenTitle7" text="Live Fleet Map" level="H3" class="sectionTitle" />
                <core:HTML id="adminMapContainer" content="&lt;div id='adminLeafletMap' style='width: 100%; height: 380px;'&gt;&lt;/div&gt;" />
            </VBox>

            <VBox id="_IDGenVBox14" height="450px" class="fleetMonitorArea">
                <layoutData><layout:GridData id="_IDGenGridData1" span="L4 M12 S12" /></layoutData>
                <Title id="_IDGenTitle8" text="Live Fleet Monitor" level="H3" class="sectionTitle"/>
                <ScrollContainer id="_IDGenScrollContainer" vertical="true" height="100%" class="fleetScroll">
                    <List id="fleetList" items="{fleet>/activeFleet}" class="fleetMonitorList">
                        <CustomListItem class="fleetListItem">
                            <VBox class="fleetItemContainer">
                                <HBox justifyContent="SpaceBetween" alignItems="Center" class="fleetTopRow">
                                    <HBox alignItems="Center" class="driverInfoContainer">
                                        <core:HTML content="&lt;div class='driver-circle'&gt;{fleet>driverInitials}&lt;/div&gt;" class="driverCircle"/>
                                        <VBox class="driverDetailsBox">
                                            <Text text="{fleet>driverName}" class="driverNameText"/>
                                            <Text text="{fleet>truckId}" class="truckNumberText"/>
                                        </VBox>
                                    </HBox>
                                    <VBox alignItems="Center" class="contactInfoBox">
                                        <Text text="{fleet>driverContact}" class="contactNumberText"/>
                                    </VBox>
                                </HBox>
                                <Button text="View Details" press="onViewFleetDetails" type="Emphasized" class="viewFleetBtn fullWidthBtn"/>
                            </VBox>
                        </CustomListItem>
                    </List>
                </ScrollContainer>
            </VBox>
        </layout:Grid>
        
        <!-- Fleet Details Side Panel -->
        <Panel id="fleetDetailsPanel" class="fleetDetailsPanel" visible="false">
            <headerToolbar>
                <Toolbar id="detailsToolbar">
                    <Title id="detailsTitle" text="Fleet Details" class="detailsPanelTitle"/>
                    <ToolbarSpacer id="detailsSpacer"/>
                    <Button id="closeDetailsBtn" icon="sap-icon://decline" press="onCloseDetails" type="Transparent"/>
                </Toolbar>
            </headerToolbar>
            <content>
                <VBox id="detailsContent" class="detailsContentBox">
                    <VBox id="locationDetails" class="locationDetailsBox">
                        <Label id="pickupLabel" text="Pickup Location:" class="detailLabel"/>
                        <Text id="pickupLocation" text="{selectedFleet>/pickupLocation}" class="detailText"/>
                        
                        <Label id="dropLabel" text="Drop Location:" class="detailLabel"/>
                        <Text id="dropLocation" text="{selectedFleet>/dropLocation}" class="detailText"/>
                        
                        <Label id="currentLabel" text="Current Location:" class="detailLabel"/>
                        <Text id="currentLocation" text="{selectedFleet>/currentLocation}" class="detailText"/>
                        
                        <Label id="contactLabel" text="Driver Contact:" class="detailLabel"/>
                        <Text id="driverContact" text="{selectedFleet>/driverContact}" class="detailText"/>
                    </VBox>
                </VBox>
            </content>
        </Panel>
    </VBox>
</mvc:View>