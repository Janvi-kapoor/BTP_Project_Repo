<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog id="loginDialog" title="{loginModel>/portalTitle}" class="simpleLoginDialog">
        <content>
            <VBox id="_IDGenVBox9" class="sapUiMediumMargin">
                <VBox id="_IDGenVBox10" class="loginFieldGroup">
                    <Label id="_IDGenLabel" text="Email Address" labelFor="emailInput" design="Bold"/>
                    <Input id="emailInput" placeholder="user@example.com" type="Email" />
                    
                    <Label id="_IDGenLabel1" text="Password" labelFor="passwordInput" design="Bold" class="sapUiSmallMarginTop"/>
                    <Input id="passwordInput" placeholder="Enter password" type="Password"/>
                </VBox>
            </VBox>
        </content>
        <beginButton>
            <Button id="_IDGenButton4" text="Login" press="onLoginSubmit" type="Emphasized" class="loginSubmitBtn"/>
        </beginButton>
        <endButton>
            <Button id="_IDGenButton5" text="Close" press="onCloseLogin" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>