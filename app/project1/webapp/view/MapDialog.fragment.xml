<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <Dialog id="mapDialog" title="Select Location" contentWidth="80%" contentHeight="550px">
        <content>
            <VBox id="leafletMapContainer" width="100%" height="450px" class="sapUiSmallMarginBottom"></VBox>
            <FormattedText id="_IDGenFormattedText1" htmlText="&lt;p style='color: #666; margin-left: 10px;'&gt;Click on the map to pin a location.&lt;/p&gt;" />
        </content>
        <buttons>
            <Button id="_IDGenButton6" text="Confirm &amp; Close" type="Emphasized" press="onCloseMapDialog" />
            <Button id="_IDGenButton7" text="Cancel" press="onCloseMapDialog" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>