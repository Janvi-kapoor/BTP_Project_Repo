<mvc:View controllerName="project1.controller.DriverDashboard" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:tnt="sap.tnt" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" displayBlock="true">
    <tnt:ToolPage id="toolPage">
        <tnt:header>
            <tnt:ToolHeader id="mainHeader" class="nexusHeader">
                <Button id="sideNavBtn" icon="sap-icon://menu2" type="Transparent" press="onSideNavButtonPress" class="headerMenuBtn"/>
                <HBox id="logoBox" alignItems="Center" class="logoContainer">
                    <core:Icon id="_IDGenIcon8" src="sap-icon://BusinessSuiteInAppSymbols/hexagon" class="logoIcon"/>
                    <Title id="_IhDGenTitle5" text="LogiChain NEXUS" class="companyLogoText"/>
                </HBox>
                <ToolbarSpacer id="_IDGefnToolbarSpacer5"/>
                <HBox id="rightSection" alignItems="Center">
                    <Button id="_IDGenBuftton3" icon="sap-icon://bell" type="Transparent" class="headerIconBtn sapUiTinyMarginEnd" tooltip="Notifications"/>
                    <core:Icon id="_IDGenIcon15" src="sap-icon://vertical-bar" class="separatorIcon sapUiTinyMarginEnd" color="#e2e8f0"/>
                    <HBox id="profileBox" alignItems="Center" class="profileSection">
                        <Avatar id="_IDGenfAvatar" src="sap-icon://person-placeholder" displaySize="XS" class="profileAvatar"/>
                        <VBox id="_IDGenfVBox11" alignItems="Start" justifyContent="Center" class="profileInfoBox sapUiTinyMarginBegin hideOnMobile">
                            <Text id="_IDGfenText18" text="Acme Logistics Ltd." class="profileName"/>
                            <Text id="_IDGenfText19" text="Ops Manager" class="profileRole"/>
                        </VBox>
                    </HBox>
                </HBox>
            </tnt:ToolHeader>
        </tnt:header>
        <tnt:sideContent>
            <tnt:SideNavigation id="sideNavigation" class="nexusSidebar" itemSelect="onItemSelect">
                <tnt:item>
                    <tnt:NavigationList id="navList">
                        <tnt:NavigationListItem id="_IDGenNavigationListItem" text="Active Mission" icon="sap-icon://locate-me" key="mission"/>
                        <tnt:NavigationListItem id="_IDGenNavigationListItem4" text="Live Navigation" icon="sap-icon://map-2" key="navigation"/>
                        <tnt:NavigationListItem id="_IDGenNavigationListItem6" text="Secure Delivery" icon="sap-icon://shield" key="secure"/>
                        <tnt:NavigationListItem id="_IDGenNavigationListItem7" text="My Performance" icon="sap-icon://kpi-managing-strategy" key="performance"/>
                    </tnt:NavigationList>
                </tnt:item>
            </tnt:SideNavigation>
        </tnt:sideContent>
        <tnt:mainContents>
            <NavContainer id="driverNavContainer">
                <Page id="missionPage" showHeader="false">
                    <VBox id="activeMissionContainer" class="contentPadding">
                        <HBox id="activeMissionHeader" alignItems="Center" class="performanceHeaderBox">
                            <core:Icon id="missionIcon" src="sap-icon://marketing-campaign" class="performanceHeaderIcon"/>
                            <Title id="missionTitle" text="Active Mission" level="H2" class="mainTitleText"/>
                        </HBox>
                        <HBox id="driverInfoBox" class="sapUiMediumMarginBottom sapUiMediumMarginBegin">
                            <HBox id="driverPill" alignItems="Center" class="drActive-infoPill sapUiMediumMarginEnd">
                                <core:Icon id="driverIcon" src="sap-icon://customer" size="1.2rem" class="sapUiTinyMarginEnd"/>
                                <VBox id="driverInfoVBox">
                                    <Text id="driverLabel" text="Driver" class="drActive-tinyLabel"/>
                                    <Text id="driverName" text="{driverData>/driverName}" class="drActive-pillMainText sapMTextBold"/>
                                </VBox>
                            </HBox>
                            <HBox id="truckPill" alignItems="Center" class="drActive-infoPill">
                                <core:Icon id="truckIcon" src="sap-icon://shipping-status" size="1.2rem" class="sapUiTinyMarginEnd"/>
                                <VBox id="truckInfoVBox">
                                    <Text id="truckLabel" text="Truck" class="drActive-tinyLabel"/>
                                    <Text id="truckNumber" text="{driverData>/truckNo}" class="drActive-pillMainText sapMTextBold"/>
                                </VBox>
                            </HBox>
                        </HBox>
                        <VBox class="drActive-missionCard sapUiMediumMargin" id="missionContainer">
                            <VBox id="_IDGenVBox28" class="drActive-missionCard-header">
                                <HBox id="missionHeaderBox" justifyContent="SpaceBetween" alignItems="Center">
                                    <VBox id="shipmentInfoVBox">
                                        <Text id="shipmentLabel" text="ACTIVE SHIPMENT" class="drActive-whiteText drActive-tinyLabel"/>
                                        <Title id="shipmentID" text="{driverData>/ID}" titleStyle="H1" class="drActive-whiteText drActive-mainShipmentID"/>
                                    </VBox>
                                    <ObjectStatus id="missionStatus" text="{driverData>/status}" state="{= ${driverData>/status} === 'In-Transit' ? 'Success' : 'Warning' }" inverted="true"/>
                                </HBox>
                            </VBox>
                            <VBox id="_IDGenVBox29" class="sapUiLargeMarginBottom">
                                <HBox id="routeBox" justifyContent="SpaceAround" alignItems="Center" class="drActive-routeBox">
                                    <VBox id="originBox" class="drActive-routePoint">
                                        <Text id="originLabel" text="ORIGIN" class="drActive-tinyLabel"/>
                                        <Text id="originLocation" text="{driverData>/pickupLocation}" class="drActive-locationText"/>
                                    </VBox>
                                    <VBox id="_IDGenVBox31" alignItems="Center" class="drActive-routeLineWrapper">
                                        <core:Icon id="routeArrow" src="sap-icon://arrow-right" size="1.5rem" class="sapUiPositiveText"/>
                                    </VBox>
                                    <VBox id="destinationBox" class="drActive-routePoint sapUiTextAlignEnd">
                                        <Text id="destinationLabel" text="DESTINATION" class="drActive-tinyLabel"/>
                                        <Text id="destinationLocation" text="{driverData>/dropLocation}" class="drActive-locationText"/>
                                    </VBox>
                                </HBox>
                                <l:Grid id="specsGrid" defaultSpan="L4 M4 S4" class="sapUiMediumMarginTop">
                                    <VBox id="weightBox" alignItems="Center" class="drActive-specItem">
                                        <core:Icon id="weightIcon" src="sap-icon://measure" size="1.8rem"/>
                                        <Text id="weightLabel" text="LOAD WEIGHT" class="drActive-tinyLabel"/>
                                        <Text id="weightValue" text="{driverData>/loadWeightTons} Tons" class="drActive-specValue sapMTextBold"/>
                                    </VBox>
                                    <VBox id="cargoBox" alignItems="Center" class="drActive-specItem">
                                        <core:Icon id="cargoIcon" src="sap-icon://product" size="1.8rem"/>
                                        <Text id="cargoLabel" text="CARGO TYPE" class="drActive-tinyLabel"/>
                                        <Text id="cargoValue" text="{driverData>/materialCategory}" class="drActive-specValue sapMTextBold"/>
                                    </VBox>
                                    <VBox id="durationBox" alignItems="Center" class="drActive-specItem">
                                        <core:Icon id="durationIcon" src="sap-icon://future" size="1.8rem"/>
                                        <Text id="durationLabel" text="EST. DURATION" class="drActive-tinyLabel"/>
                                        <Text id="durationValue" text="3-4 Hours" class="drActive-specValue sapMTextBold"/>
                                    </VBox>
                                </l:Grid>
                                <!-- Conditional Action Section -->
                                <Button id="startMissionBtn" text="START MISSION" type="Emphasized" press="onStartTrip" class="drActive-startBtn" icon="sap-icon://arrow-right" iconFirst="false" visible="{= ${driverData>/status} !== 'In-Transit' }"/>
                                <VBox id="tripStartedMessage" visible="{= ${driverData>/status} === 'In-Transit' }" alignItems="Center" class="sapUiMediumMarginTop">
                                    <core:Icon id="_IDGenIcon17" src="sap-icon://accept" size="2rem" color="#10b981" class="sapUiTinyMarginBottom"/>
                                    <Text id="_IDGenText45" text="The trip has started" class="drActive-specValue sapMTextBold sapUiPositiveText"/>
                                </VBox>
                            </VBox>
                        </VBox>
        <l:Grid id="kpiGrid" defaultSpan="L4 M6 S12" class="sapUiMediumMarginTop sapUiMediumMarginBeginEnd drActive-kpiContainer">
   <VBox id="distanceKpiCard" class="drActive-kpiCard">
    <Text id="_IDGenText46" text="Total Distance" class="drActive-tinyLabel"/>
    <Title id="_IDGenTitle18" text="{perfModel>/totalDistance} KM" titleStyle="H2"/>
</VBox>

<VBox id="rateKpiCard" class="drActive-kpiCard">
    <Text id="_IDGenText47" text="Assigned Truck Type" class="drActive-tinyLabel"/>
    <Title id="_IDGenTitle19" text="{perfModel>/truckType}" titleStyle="H2" class="sapUiPositiveText"/>
</VBox>
<VBox id="fareKpiCard" class="drActive-kpiCard">
        <Text id="_IDGenText49" text="Trip Fare" class="drActive-tinyLabel"/>
       <Title id="_IDGenTitle17" 
       text="{
           parts: [
               {path: 'perfModel>/totalFare'},
               {value: 'INR'}
           ],
           type: 'sap.ui.model.type.Currency',
           formatOptions: {
               showMeasure: true,
               currencyCode: false
           }
       }" 
       titleStyle="H2" 
       color="#6366f1"/>
    </VBox>
</l:Grid>
                    </VBox>
                    <VBox id="noTaskContainer" visible="false" alignItems="Center" class="sapUiLargeMarginTop">
    <core:Icon id="_IDGenIcon16" src="sap-icon://message-success" size="4rem" color="#ccc" />
    <Title id="_IDGenTitle16" text="No tasks currently assigned to you." class="sapUiSmallMarginTop" />
    <Text id="_IDGenText44" text="Please wait for the administrator to assign a new shipment." />
</VBox>
                </Page>
            </NavContainer>
        </tnt:mainContents>
    </tnt:ToolPage>
</mvc:View>