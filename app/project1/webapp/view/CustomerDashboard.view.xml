<mvc:View controllerName="project1.controller.CustomerDashboard" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:tnt="sap.tnt" xmlns:core="sap.ui.core" xmlns:layout="sap.ui.layout" displayBlock="true">
    <tnt:ToolPage id="toolPage" class="nexusToolPage">
        <tnt:header>
            <tnt:ToolHeader id="mainHeader" class="nexusHeader">
                <Button id="sideNavBtn" icon="sap-icon://menu2" type="Transparent" press="onSideNavButtonPress" class="headerMenuBtn"/>
                <HBox id="logoBox" alignItems="Center" class="logoContainer">
                    <core:Icon id="_IDGenIcon7" src="sap-icon://BusinessSuiteInAppSymbols/hexagon" class="logoIcon"/>
                    <Title id="_IDGenTitle5" text="LogiChain NEXUS" class="companyLogoText"/>
                </HBox>
                <ToolbarSpacer id="_IDGenToolbarSpacer5"/>
                <HBox id="rightSection" alignItems="Center">
                    <Button id="customerNotificationBtn" icon="sap-icon://bell" type="Transparent" class="headerIconBtn sapUiTinyMarginEnd" tooltip="Notifications" press="onNotificationPress"/>
                    <core:Icon id="_IDGenIcon15" src="sap-icon://vertical-bar" class="separatorIcon sapUiTinyMarginEnd" color="#e2e8f0"/>
                    <HBox id="profileBox" alignItems="Center" class="profileSection">
                        <Avatar id="_IDGenAvatar" src="sap-icon://person-placeholder" displaySize="XS" class="profileAvatar"/>
                        <VBox id="_IDGenVBox11" alignItems="Start" justifyContent="Center" class="profileInfoBox sapUiTinyMarginBegin hideOnMobile">
                            <Text id="_IDGenText18" text="{companyName}" class="profileName"/>
                            <Text id="_IDGenText19" text="{email}" class="profileRole"/>
                        </VBox>
                        <Button id="logoutBtn" icon="sap-icon://log" type="Transparent" class="headerIconBtn sapUiTinyMarginBegin" tooltip="Logout" press="onLogout"/>
                    </HBox>
                </HBox>
            </tnt:ToolHeader>
        </tnt:header>
        <tnt:sideContent>
            <tnt:SideNavigation id="_IDGenSideNavigation" class="nexusSidebar" itemSelect="onItemSelect">
                <tnt:NavigationList id="navList" class="sapTntNavListItem">
                    <tnt:NavigationListItem id="navDash" text="Dashboard" icon="sap-icon://grid" key="dash"/>
                    <tnt:NavigationListItem id="navBooking" text="New Booking" icon="sap-icon://add" key="booking"/>
                    <tnt:NavigationListItem id="navTrack" text="Track Shipments" icon="sap-icon://map-2" key="track"/>
                    <tnt:NavigationListItem id="navHistory" text="Order History" icon="sap-icon://history" key="history"/>
                </tnt:NavigationList>
            </tnt:SideNavigation>
        </tnt:sideContent>
        <tnt:mainContents>
            <NavContainer id="pageNavContainer">
                <Page id="dashPage" showHeader="false" class="dashboardBackground">
                    <ScrollContainer id="_IDGenScrollContainer" height="100%" vertical="true" horizontal="false">
                        <VBox id="_IDGenVBox12" class="contentWrapper">
                            <VBox id="_IDGenVBox27" class="sapUiMediumMarginBottom">
                                <Title id="_IDGenTitle6" text="Operations Overview" level="H1" class="pageTitle"/>
                                <Text id="_IDGenText45" text="Welcome back, here is your daily logistics summary." class="pageSubtitle"/>
                            </VBox>
                            <layout:Grid id="_IDGenGrid1" containerQuery="true" defaultSpan="XL4 L4 M6 S12" vSpacing="1rem" hSpacing="1rem">
                                <VBox id="_IDGenVBox14" class="kpiCard">
                                    <HBox id="_IDGenHBox8" justifyContent="SpaceBetween" alignItems="Start">
                                        <VBox id="_IDGenVBox15">
                                            <Text id="_IDGenText21" text="Active Shipments" class="kpiLabel"/>
                                            <Title id="_IDGenTitle7" text="{metrics>/active}" class="kpiValue"/>
                                        </VBox>
                                        <core:Icon id="_IDGenIcon8" src="sap-icon://shipping-status" class="kpiIcon iconPurple"/>
                                    </HBox>
                                    <HBox id="_IDGenHBox14" alignItems="Center" class="sapUiTinyMarginTop">
                                        <core:Icon id="_IDGenIcon9" src="sap-icon://trend-up" class="trendIcon positive"/>
                                        <Text id="_IDGenText22" text="+12.5% this week" class="trendText"/>
                                    </HBox>
                                </VBox>
                                <VBox id="_IDGenVBox16" class="kpiCard">
                                    <HBox id="_IDGenHBox15" justifyContent="SpaceBetween" alignItems="Start">
                                        <VBox id="_IDGenVBox17">
                                            <Text id="_IDGenText23" text="Pending Dispatch" class="kpiLabel"/>
                                            <Title id="_IDGenTitle8" text="{metrics>/pending}" class="kpiValue"/>
                                        </VBox>
                                        <core:Icon id="_IDGenIcon10" src="sap-icon://history" class="kpiIcon iconBlue"/>
                                    </HBox>
                                    <HBox id="_IDGenHBox16" alignItems="Center" class="sapUiTinyMarginTop">
                                        <core:Icon id="_IDGenIcon12" src="sap-icon://trend-down" class="trendIcon negative"/>
                                        <Text id="_IDGenText24" text="-8.3% pending" class="trendText"/>
                                    </HBox>
                                </VBox>
                                <VBox id="_IDGenVBox18" class="kpiCard">
                                    <HBox id="_IDGenHBox17" justifyContent="SpaceBetween" alignItems="Start">
                                        <VBox id="_IDGenVBox19">
                                            <Text id="_IDGenText25" text="Monthly Spend" class="kpiLabel"/>
                                            <Title id="_IDGenTitle9" text="₹ {metrics>/spend}" class="kpiValue"/>
                                        </VBox>
                                        <core:Icon id="_IDGenIcon13" src="sap-icon://money-bills" class="kpiIcon iconGreen"/>
                                    </HBox>
                                    <HBox id="_IDGenHBox18" alignItems="Center" class="sapUiTinyMarginTop">
                                        <core:Icon id="_IDGenIcon14" src="sap-icon://trend-up" class="trendIcon positive"/>
                                        <Text id="_IDGenText26" text="+5.2% vs last month" class="trendText"/>
                                    </HBox>
                                </VBox>
                            </layout:Grid>
                            <VBox id="_IDGenVBox20" class="modernCard sapUiMediumMarginTop">
                                <VBox id="_IDGenVBox21" class="sapUiSmallMargin">
                                    <Table id="recentShipmentsTable" items="{
        path: '/AdminShipments',
        parameters: {
            '$expand': 'customer,assignment'
        },
        filters: [
            {
                path: 'status',
                operator: 'NE',
                value1: 'Delivered'
            },
            {
                path: 'status',
                operator: 'NE',
                value1: 'Cancelled'
            }
        ]
    }" class="nexusTable">
                                        <headerToolbar>
                                            <OverflowToolbar id="_IDGenOverflowToolbar11" class="bottomLineToolbar" style="Clear">
                                                <Title id="_IDGenTitleHistoryTable" text="Your Orders" class="tableTitle"/>
                                                <ToolbarSpacer id="_IDGenToolbarSpacerHistory"/>
                                                <SearchField id="historySearchField" width="30%" search="onHistorySearch" placeholder="Search by Material..."/>
                                                <MenuButton id="historyFilterMenuButton2" icon="sap-icon://filter">
                                                    <menu>
                                                        <Menu id="_IDGenMenu2" itemSelected="onStatusFilterChange">
                                                            <items>
                                                                <MenuItem id="_IDGenMenuItem1" text="All Status" key="All" icon="sap-icon://multiselect-all"/>
                                                                <MenuItem id="_IDGenMenuItem2" text="In-Transit" key="In-Transit" icon="sap-icon://shipping-status"/>
                                                                <MenuItem id="_IDGenMenuItem3" text="Pending" key="Pending" icon="sap-icon://pending"/>
                                                                <MenuItem id="_IDGenMenuItem4" text="Confirm Pickup" key="ConfirmPickup" icon="sap-icon://shipping-status"/>
                                                            </items>
                                                        </Menu>
                                                    </menu>
                                                </MenuButton>
                                            </OverflowToolbar>
                                        </headerToolbar>
                                        <columns>
                                            <Column id="_IDGenColH1" width="23%">
                                                <Text id="_IDGenText27" text="Shipment ID"/>
                                            </Column>
                                            <Column id="_IDGenColH4" width="23%">
                                                <Text id="_IDGenText28" text="Material"/>
                                            </Column>
                                            <Column id="_IDGenColH2" width="21%">
                                                <Text id="_IDGenText29" text="Destination"/>
                                            </Column>
                                            <Column id="_IDGenColumn6" width="12%">
                                                <Text id="_IDGenText30" text="Status"/>
                                            </Column>
                                            <Column id="_IDGenColH5" width="16%">
                                                <Text id="_IDGenText31" text="Fare"/>
                                            </Column>
                                            <Column id="_IDGenColH6" width="15%">
                                                <Text id="_IDGenText33" text="ETA"/>
                                            </Column>
                                        </columns>
                                        <items>
                                            <ColumnListItem id="_IDGenCLIHistory" vAlign="Middle">
                                                <cells>
                                                    <Link id="_IDGenText35" text="{ID}" class="boldText orderIdText shipmentIdText clickableShipmentId" press="onShipmentIdPress"/>
                                                    <Text id="_IDGenText39" text="{materialCategory}"/>
                                                    <Text id="_IDGenText40" text="{dropLocation}" class="sapUiFontWeightBold myBoldText"/>
                                                    <Text id="_IDGenText41" text="{status}"/>
                                                    <Text id="_IDGenText42" text="₹ {totalFare}"/>
                                                    <Text id="_IDGenText60" text="{= ${assignment/eta} ? ${assignment/eta} : 'Not Assigned' }"/>
                                                </cells>
                                            </ColumnListItem>
                                        </items>
                                    </Table>
                                </VBox>
                            </VBox>
                            <HBox id="_IDGenHBox23" height="60px"/>
                        </VBox>
                    </ScrollContainer>
                </Page>
                <Page id="bookingPage" showHeader="false">
                    <mvc:XMLView id="_IDGenXMLView1" viewName="project1.view.NewBooking"/>
                </Page>
                <Page id="trackPage" showHeader="false">
                    <mvc:XMLView id="_IDGenXMLView2" viewName="project1.view.TrackShipments"/>
                </Page>
                <Page id="historyPage" showHeader="false">
                    <mvc:XMLView id="_IDGenXMLView3" viewName="project1.view.OrderHistory"/>
                </Page>
            </NavContainer>
        </tnt:mainContents>
    </tnt:ToolPage>
</mvc:View>
