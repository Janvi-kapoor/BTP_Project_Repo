<mvc:View
    controllerName="project1.controller.CustomerDashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    displayBlock="true">

    <tnt:ToolPage id="toolPage" class="nexusToolPage">
        <tnt:header>
            <tnt:ToolHeader id="_IDGenToolHeader1" class="nexusHeader">
                <Button id="_IDGenButton3" icon="sap-icon://menu2" type="Transparent" press="onSideNavButtonPress" class="menuBtn"/>
                <HBox id="_IDGenHBox5" alignItems="Center" class="sapUiSmallMarginBegin">
                    <core:Icon id="_IDGenIcon7" src="sap-icon://BusinessSuiteInAppSymbols/hexagon" class="logoIcon" color="#6366f1"/>
                    <Title id="_IDGenTitle5" text="LogiChain NEXUS" class="logoText"/>
                </HBox>
                <ToolbarSpacer id="_IDGenToolbarSpacer4" />
                <Button id="_IDGenButton6" icon="sap-icon://bell" type="Transparent" class="headerIcon"/>
                <Avatar id="_IDGenAvatar" src="sap-icon://person-placeholder" displaySize="XS" class="userAvatar sapUiSmallMarginEnd" />
            </tnt:ToolHeader>
        </tnt:header>

        <tnt:sideContent>
            <tnt:SideNavigation id="_IDGenSideNavigation" class="nexusSidebar" itemSelect="onItemSelect">
                <tnt:NavigationList id="_IDGenNavigationList">
                    <tnt:NavigationListItem id="_IDGenNavigationListItem" text="Dashboard" icon="sap-icon://grid" key="dash" />
                    <tnt:NavigationListItem id="_IDGenNavigationListItem1" text="New Booking" icon="sap-icon://add" key="booking" />
                    <tnt:NavigationListItem id="_IDGenNavigationListItem2" text="Track Shipments" icon="sap-icon://map-2" key="track" />
                    <tnt:NavigationListItem id="_IDGenNavigationListItem3" text="Order History" icon="sap-icon://history" key="history" />
                </tnt:NavigationList>
            </tnt:SideNavigation>
        </tnt:sideContent>

        <tnt:mainContents>
            <NavContainer id="pageNavContainer">
                
                <Page id="dashPage" showHeader="false">
                    <ScrollContainer id="_IDGenScrollContainer" vertical="true" horizontal="false" height="100%">
                        <VBox id="_IDGenVBox11" class="contentPadding">
                            <VBox id="_IDGenVBox12" class="sapUiLargeMarginBottom">
                                <Title id="_IDGenTitle6" text="Operations Dashboard" level="H1" class="mainTitleText" />
                                <Text id="_IDGenText18" text="Real-time overview of your logistics operations" class="subTitleText" />
                            </VBox>

                            <layout:Grid id="_IDGenGrid1" containerQuery="true" defaultSpan="XL4 L4 M4 S12" class="kpiGrid">
                                <VBox id="_IDGenVBox13" class="modernCard kpiCardAnimate">
                                    <VBox id="_IDGenVBox14" class="iconBox purpleIcon sapUiSmallMarginBottom">
                                        <core:Icon id="_IDGenIcon8" src="sap-icon://shipping-status" size="1.5rem"/>
                                    </VBox>
                                    <Text id="_IDGenText19" text="Active Shipments" class="cardLabel"/>
                                    <Title id="_IDGenTitle7" text="847" class="cardValue"/>
                                </VBox>
                                <VBox id="_IDGenVBox15" class="modernCard kpiCardAnimate">
                                    <VBox id="_IDGenVBox16" class="iconBox blueIcon sapUiSmallMarginBottom">
                                        <core:Icon id="_IDGenIcon9" src="sap-icon://clock" size="1.5rem"/>
                                    </VBox>
                                    <Text id="_IDGenText20" text="Pending Dispatch" class="cardLabel"/>
                                    <Title id="_IDGenTitle8" text="156" class="cardValue"/>
                                </VBox>
                                <VBox id="_IDGenVBox17" class="modernCard kpiCardAnimate">
                                    <VBox id="_IDGenVBox18" class="iconBox greenIcon sapUiSmallMarginBottom">
                                        <core:Icon id="_IDGenIcon10" src="sap-icon://waiver" size="1.5rem"/>
                                    </VBox>
                                    <Text id="_IDGenText21" text="Monthly Spend" class="cardLabel"/>
                                    <Title id="_IDGenTitle9" text="₹ 28,47,500" class="cardValue"/>
                                </VBox>
                            </layout:Grid>

                            <VBox id="_IDGenVBox19" class="modernCard tableCard sapUiMediumMarginTop">
                                <VBox id="_IDGenVBox20" class="tableHeader">
                                    <Title id="_IDGenTitle10" text="Live Inventory Movement" level="H2" class="tableTitle"/>
                                    <Text id="_IDGenText22" text="Real-time tracking of all active shipments" class="tableSubTitle"/>
                                </VBox>
                                <Table id="_IDGenTable" items="{/shipments}" class="nexusTable">
                                    <columns>
                                        <Column id="_IDGenColumn"><Text id="_IDGenText23" text="Shipment ID" /></Column>
                                        <Column id="_IDGenColumn1"><Text id="_IDGenText24" text="Material" /></Column>
                                        <Column id="_IDGenColumn2"><Text id="_IDGenText25" text="Destination" /></Column>
                                        <Column id="_IDGenColumn3"><Text id="_IDGenText26" text="Status" /></Column>
                                        <Column id="_IDGenColumn4" hAlign="End"><Text id="_IDGenText27" text="ETA" /></Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem id="_IDGenColumnListItem">
                                            <cells>
                                                <Text id="_IDGenText28" text="{id}" class="shipmentIdText" />
                                                <Text id="_IDGenText29" text="{material}" />
                                                <Text id="_IDGenText30" text="{destination}" />
                                                <VBox id="_IDGenVBox21" class="statusContainer">
                                                    <Text id="_IDGenText31" text="{status}" class="statusLabel {statusClass}"/>
                                                </VBox>
                                                <Text id="_IDGenText33" text="{eta}" class="etaText" />
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </VBox>
                        </VBox>
                    </ScrollContainer>
                </Page>

                <Page id="bookingPage" showHeader="false">
                    <VBox id="_IDGenVBox25" class="contentPadding">
                         <Title id="_IDGenTitle14" text="New Booking" level="H1" class="mainTitleText" />
                         <Text id="_IDGenText34" text="Create a new shipment request here." class="subTitleText" />
                         </VBox>
                </Page>

            </NavContainer>
        </tnt:mainContents>
    </tnt:ToolPage>
</mvc:View>