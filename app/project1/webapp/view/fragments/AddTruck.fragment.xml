<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:form="sap.ui.layout.form">
    <Dialog id="addTruckDialog" title="Add New Truck" contentWidth="400px">
        <content>
            <form:SimpleForm id="_IDGenSimpleForm1" editable="true" layout="ResponsiveGridLayout">
                <form:content>
                    <Label id="_IDGenLabel12" text="Truck Number" required="true"/>
                    <Input id="_IDGenInput" value="{newTruck>/truckNo}" placeholder="Ex: MH-12-AB-1234" />

                    <Label id="_IDGenLabel13" text="Vehicle Type" required="true"/>
                    <Select id="_IDGenSelect3" selectedKey="{newTruck>/vehicleType}">
                        <core:Item id="_IDGenItem5" key="Heavy Duty" text="Heavy Duty" />
                        <core:Item id="_IDGenItem6" key="Medium Duty" text="Medium Duty" />
                        <core:Item id="_IDGenItem7" key="Light Duty" text="Light Duty" />
                    </Select>

                    <Label id="_IDGenLabel14" text="Max Capacity (Tons)" />
                    <StepInput id="_IDGenStepInput1" value="{newTruck>/maxCapacityTons}" min="1" max="50" step="0.5" />

                    <Label id="_IDGenLabel15" text="Odometer (KM)" />
                    <Input id="_IDGenInput4" value="{newTruck>/odometerKM}" type="Number" />

                    <Label id="_IDGenLabel16" text="Status" />
                    <Select id="_IDGenSelect4" selectedKey="{newTruck>/status}">
                        <core:Item id="_IDGenItem8" key="AVAILABLE" text="Available" />
                        <core:Item id="_IDGenItem9" key="MAINTENANCE" text="Maintenance" />
                        <core:Item id="_IDGenItem10" key="ON_TRIP" text="On Trip" />
                    </Select>
                </form:content>
            </form:SimpleForm>
        </content>
        <beginButton>
            <Button id="_IDGenButton11" text="Save" type="Emphasized" press=".onSaveTruck" />
        </beginButton>
        <endButton>
            <Button id="_IDGenButton12" text="Cancel" press=".onCancelTruck" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>