<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog id="liveLocationDialog" title="Live Driver Location" contentWidth="600px" contentHeight="550px">
        <content>
            <VBox id="liveMapContainer" width="100%" height="450px" class="sapUiSmallMargin">
                <html:div xmlns:html="http://www.w3.org/1999/xhtml" 
                    id="liveDriverMap" 
                    style="width: 100%; height: 450px; border: 1px solid #ccc; border-radius: 8px;">
                </html:div>
            </VBox>
            <VBox class="sapUiSmallMargin">
                <Text id="liveDriverCoordText" text="Fetching real-time location..." textAlign="Center" width="100%"/>
            </VBox>
        </content>
        <beginButton>
            <Button id="liveLocationCloseButton" text="Close" press="onCloseLocationDialog" type="Emphasized"/>
        </beginButton>
    </Dialog>
</core:FragmentDefinition>