{
  "welcomeFile": "/comlogirouteapp/index.html",
  "authenticationMethod": "route",
  "whitelistService": {
    "endpoint": "/external/v1/whitelist"
  },
  "routes": [
    {
      "source": "^/odata/v4/logi-chain/(.*)$",
      "target": "/odata/v4/logi-chain/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    }
  ]
}